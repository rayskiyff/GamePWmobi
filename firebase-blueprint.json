{
  "entities": {
    "User": {
      "title": "User",
      "description": "Public user profile",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "race": { "type": "string", "enum": ["human", "mage"] },
        "aboutMe": { "type": "string" },
        "hideAllInfo": { "type": "boolean" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["userId", "username", "email", "createdAt"]
    },
    "UserPrivate": {
      "title": "User Private Info",
      "description": "Sensitive information like real name and dob",
      "type": "object",
      "properties": {
        "realName": { "type": "string" },
        "dob": { "type": "string" },
        "showRealName": { "type": "boolean" },
        "showDob": { "type": "boolean" }
      }
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Game base characteristics and stats",
      "type": "object",
      "properties": {
        "level": { "type": "number" },
        "experience": { "type": "number" },
        "strength": { "type": "number" },
        "agility": { "type": "number" },
        "intuition": { "type": "number" },
        "endurance": { "type": "number" },
        "intelligence": { "type": "number" },
        "wisdom": { "type": "number" },
        "matchesPlayed": { "type": "number" },
        "wins": { "type": "number" },
        "losses": { "type": "number" }
      },
      "required": ["level", "experience", "strength", "agility", "intuition", "endurance", "intelligence", "wisdom", "matchesPlayed", "wins", "losses"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    },
    "users/{userId}/private/info": {
      "schema": "UserPrivate",
      "description": "Private PII for user"
    },
    "users/{userId}/stats/current": {
      "schema": "UserStats",
      "description": "User characteristics"
    }
  }
}
